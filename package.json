  "dependencies": {
    "@anthropic-ai/sdk": "^0.19.0",
    "@raycast/api": "^1.104.19",
    "capitalize": "^2.0.4",
    "eventsource-parser": "^1.1.1",
    "google-auth-library": "^8.8.0",
    "iso-639-1": "^2.1.15",
    "iso-639-3-to-1": "^1.0.0",
    "node-fetch": "^3.3.0",
    "socks-proxy-agent": "^7.0.0",
    "stream-json": "^1.8.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.6",
    "@types/capitalize": "^2.0.0",
    "@types/node": "^22.19.17",
    "@types/react": "^19.0.10",
    "@types/stream-json": "^1.7.7",
    "@types/uuid": "^9.0.1",
    "eslint": "^8.51.0",
    "prettier": "^3.0.3",
    "tsx": "^4.22.4",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "build": "ray build -e dist",
    "build-swift": "swift build --configuration=release --arch arm64 --arch x86_64 && mv .build/apple/Products/Release/{ocr,lang} assets",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "ray publish",
    "test": "tsx src/tools.test.ts && tsx src/runtime/tool-runtime.test.ts"
  }
}
