{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "kraft",
  "title": "Kraft",
  "description": "Composable AI tools for text, clipboard, selection, OCR, workflows, and conversation.",
  "icon": "extension_icon.png",
  "author": "kilingzhang",
  "categories": [
    "Applications",
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "translate",
      "title": "Kraft",
      "subtitle": "AI Tools",
      "description": "Open Kraft's AI tool menu powered by your configured API-compatible runtime.",
      "icon": "extension_icon.png",
      "mode": "view"
    },
    {
      "name": "selected",
      "title": "Ask Selected Text",
      "description": "Run the default AI tool on selected text from the frontmost application.",
      "icon": "extension_icon.png",
      "mode": "no-view"
    },
    {
      "name": "clipboard",
      "title": "Ask Clipboard",
      "description": "Run the default AI tool on clipboard text.",
      "icon": "extension_icon.png",
      "mode": "no-view"
    },
    {
      "name": "ocr",
      "title": "Ask Screenshot Text",
      "description": "Capture text from an image region and run the default AI tool.",
      "icon": "extension_icon.png",
      "mode": "no-view",
      "preferences": [
        {
          "name": "language",
          "type": "dropdown",
          "required": false,
          "title": "Prefer Language",
          "default": "en-US",
          "description": "Prefer language to detect",
          "data": [
            {
              "value": "en-US",
              "title": "English"
            },
            {
              "value": "fr-FR",
              "title": "Français"
            },
            {
              "value": "it-IT",
              "title": "Italiano"
            },
            {
              "value": "de-DE",
              "title": "Deutsch"
            },
