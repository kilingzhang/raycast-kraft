              "title": "Português"
            },
            {
              "value": "zh-Hans",
              "title": "简体中文"
            },
            {
              "value": "zh-Hant",
              "title": "正體中文"
            },
            {
              "value": "yue-Hans",
              "title": "粤语（简体）"
            },
            {
              "value": "yue-Hant",
              "title": "粵語（正體）"
            },
            {
              "value": "ko-KR",
              "title": "한국어"
            },
            {
              "value": "ja-JP",
              "title": "日本語"
            },
            {
              "value": "ru-RU",
              "title": "Русский"
            },
            {
              "value": "uk-UA",
              "title": "Українська"
            },
            {
              "value": "th-TH",
              "title": "ภาษาไทย"
            },
            {
              "value": "vi-VT",
              "title": "Tiếng Việt"
            }
          ]
        },
        {
          "name": "level",
          "type": "dropdown",
          "required": false,
          "title": "Level",
          "default": "accurate",
          "description": "A value that determines whether the request prioritizes accuracy or speed in text recognition.",
          "data": [
            {
              "value": "accurate",
              "title": "Accurate"
            },
            {
              "value": "fast",
              "title": "Fast"
            }
          ]
        },
        {
          "name": "customWords",
          "type": "textfield",
          "required": false,
          "title": "Custom Words",
          "default": "",
          "description": "An array of strings to supplement the recognized languages at the word-recognition stage.",
          "placeholder": "An array of words split by ', '. ex: a, b, c"
        }
      ]
    }
  ],
