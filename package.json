    },
    {
      "name": "isAutoLoadSelected",
      "label": "Enable auto-load selected text",
      "description": "Load selected text from your frontmost application to the search bar automatically",
      "type": "checkbox",
      "title": "Auto-load Selected",
      "default": false,
      "required": false
    },
    {
      "name": "isAutoLoadClipboard",
      "label": "Enable auto-load clipboard text",
      "description": "Load selected text from your frontmost application to the search bar automatically",
      "type": "checkbox",
      "default": false,
      "required": false
    },
    {
      "name": "isAutoStart",
      "label": "Enable auto-start tool run",
      "description": "Auto-start the active tool when the search bar is filled by selected text, clipboard text, or OCR.",
      "type": "checkbox",
      "default": false,
      "required": false
    },
    {
      "name": "isAutoCopy2Clipboard",
      "label": "Enable auto-copy to clipboard after tool run",
      "description": "Auto-copy the tool result to the clipboard.",
      "type": "checkbox",
      "default": true,
      "required": false
    },
    {
      "name": "maxHistorySize",
      "description": "Enter a *number* as max history size",
      "type": "textfield",
      "title": "Max History Size",
      "required": false,
      "default": "30"
    },
    {
      "name": "alwayShowMetadata",
      "label": "Alway show metadata",
      "description": "Toggle default visibility of metadata in the result detail view",
      "type": "checkbox",
      "title": "Metadata Visiability",
      "required": false,
      "default": true
    },
    {
      "name": "useProxy",
      "label": "Enable proxy for each request",
      "description": "Each request will be passed through the proxy",
      "type": "checkbox",
      "title": "Use Proxy",
      "required": false,
      "default": false
    },
    {
      "name": "proxyHost",
      "description": "Sever address of the proxy",
      "type": "textfield",
      "title": "Socks5 Proxy Host",
      "required": false
    },
    {
      "name": "proxyPort",
      "description": "Server port of the proxy",
      "type": "textfield",
      "title": "Socks5 Proxy Port",
      "required": false
    },
    {
      "name": "proxyUsername",
      "description": "Leave empty if doesn't have",
      "type": "textfield",
      "title": "Socks5 Proxy Username",
      "required": false
    },
    {
      "name": "proxyPassword",
      "description": "Leave empty if doesn't have",
      "type": "password",
      "title": "Socks5 Proxy Password",
      "required": false
    }
